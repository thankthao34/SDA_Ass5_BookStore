meta {
  name: 01 Create Customer (auto-create cart)
  type: http
  seq: 1
}

post {
  url: {{customer_service_url}}/customers/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Demo Student",
    "email": "demo.student@example.com"
  }
}

script:post-response {
  const data = res.getBody();
  if (data && data.id) {
    bru.setVar("customer_id", data.id);
  }
}
