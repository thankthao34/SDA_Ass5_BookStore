meta {
  name: 03 Create Book
  type: http
  seq: 3
}

post {
  url: {{book_service_url}}/books/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "Designing Data-Intensive Applications",
    "author": "Martin Kleppmann",
    "price": "39.99",
    "stock": 20
  }
}

script:post-response {
  const data = res.getBody();
  if (data && data.id) {
    bru.setVar("book_id", data.id);
  }
}
